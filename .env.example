# Core
PROJECT_NAME="gialaitravel-ai-serivce-v2"
APP_HOST=0.0.0.0
APP_PORT=8000


# LLM Provider Configuration
# Choose one of: openai, gemini, deepseek
LLM_PROVIDER="gemini"

# API Keys (Fill in the ones you use)
OPENAI_API_KEY=""
GEMINI_API_KEY=""
DEEPSEEK_API_KEY=""
TAVILY_API_KEY=""
TAVILY_TIMEOUT_SECONDS=15
TAVILY_MAX_RETRIES=2
GOOGLE_MAPS_API_KEY=""

# Model selection for each provider
OPENAI_MODEL="gpt-4o"
GEMINI_MODEL="gemini-1.5-pro"
DEEPSEEK_MODEL="deepseek-chat"

# Vector Database (Qdrant Cloud or Local)
# For local memory: ":memory:"
# For local docker: "http://localhost:6333"
# For Qdrant Cloud: "https://<your-cluster-url>.qdrant.tech"
QDRANT_URL="https://your-cluster-url.qdrant.tech"
QDRANT_API_KEY=""
QDRANT_COLLECTION_NAME="gialai-data"
EMBEDDING_MODEL="models/gemini-embedding-2"

# LangSmith Observability
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="gialai-travel-planner"
LANGSMITH_TRACING="true"
